[Unit]
Description=Refresh PVE DCV Integration hosted artifacts
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/pve-dcv-integration/host.env
ExecStart=__INSTALL_DIR__/scripts/refresh-host-artifacts.sh
WorkingDirectory=__INSTALL_DIR__

[Install]
WantedBy=multi-user.target
