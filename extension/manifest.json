{
  "manifest_version": 3,
  "name": "PVE DCV Integration",
  "version": "0.2.0",
  "description": "Adds a DCV action to Proxmox VE VM pages and resolves launch targets from API and metadata.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "pve-dcv-integration@meinzeug"
    }
  }
}
