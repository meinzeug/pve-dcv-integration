{
  "manifest_version": 3,
  "name": "Beagle OS Integration",
  "version": "3.4.0",
  "description": "Adds Beagle profile, installer and control-plane actions to Proxmox VE VM pages.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "beagle-os@meinzeug"
    }
  }
}
