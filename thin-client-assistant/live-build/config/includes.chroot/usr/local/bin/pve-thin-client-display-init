#!/usr/bin/env bash
set -euo pipefail

if ! command -v xrandr >/dev/null 2>&1; then
  exit 0
fi

tries="${PVE_THIN_CLIENT_DISPLAY_WAIT_TRIES:-12}"
sleep_seconds="${PVE_THIN_CLIENT_DISPLAY_WAIT_SECONDS:-1}"
first_connected=""
query=""

for _ in $(seq 1 "$tries"); do
  query="$(xrandr --query 2>/dev/null || true)"
  first_connected="$(
    printf '%s\n' "$query" | awk '/ connected/{print $1; exit}'
  )"
  if [[ -n "$first_connected" ]]; then
    break
  fi
  sleep "$sleep_seconds"
done

[[ -n "$first_connected" ]] || exit 0

while read -r output_name; do
  [[ -n "$output_name" ]] || continue
  xrandr --output "$output_name" --auto >/dev/null 2>&1 || true
done < <(printf '%s\n' "$query" | awk '/ connected/{print $1}')

xrandr --output "$first_connected" --primary >/dev/null 2>&1 || true

exit 0
