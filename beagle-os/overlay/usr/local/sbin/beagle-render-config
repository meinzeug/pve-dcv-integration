#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/etc/beagle-os"
ENDPOINT_FILE="$STATE_DIR/endpoint.env"
WRITE_CONFIG="/usr/local/lib/pve-thin-client/installer/write-config.sh"
RUNTIME_USER="thinclient"
AUTOSTART=""
PROFILE_NAME="default"
MOONLIGHT_HOST=""
MOONLIGHT_APP="Desktop"
MOONLIGHT_RESOLUTION="auto"
MOONLIGHT_FPS="60"
MOONLIGHT_BITRATE="20000"
MOONLIGHT_VIDEO_CODEC="H.264"
MOONLIGHT_VIDEO_DECODER="auto"
MOONLIGHT_AUDIO_CONFIG="stereo"
MOONLIGHT_ABSOLUTE_MOUSE="1"
MOONLIGHT_QUIT_AFTER="0"
SUNSHINE_API_URL=""
SUNSHINE_USERNAME=""
SUNSHINE_PASSWORD=""
SUNSHINE_PIN=""
PROXMOX_HOST=""
PROXMOX_PORT="8006"
PROXMOX_NODE=""
PROXMOX_VMID=""
PROXMOX_REALM="pam"
PROXMOX_VERIFY_TLS="0"
NETWORK_MODE="dhcp"
NETWORK_INTERFACE=""
NETWORK_STATIC_ADDRESS=""
NETWORK_STATIC_PREFIX="24"
NETWORK_GATEWAY=""
NETWORK_DNS_SERVERS="1.1.1.1 8.8.8.8"

if [[ -r "$ENDPOINT_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENDPOINT_FILE"
  AUTOSTART="${BEAGLE_ENDPOINT_AUTOSTART:-$AUTOSTART}"
  PROFILE_NAME="${BEAGLE_ENDPOINT_PROFILE_NAME:-$PROFILE_NAME}"
  MOONLIGHT_HOST="${BEAGLE_ENDPOINT_MOONLIGHT_HOST:-$MOONLIGHT_HOST}"
  MOONLIGHT_APP="${BEAGLE_ENDPOINT_MOONLIGHT_APP:-$MOONLIGHT_APP}"
  MOONLIGHT_RESOLUTION="${BEAGLE_ENDPOINT_MOONLIGHT_RESOLUTION:-$MOONLIGHT_RESOLUTION}"
  MOONLIGHT_FPS="${BEAGLE_ENDPOINT_MOONLIGHT_FPS:-$MOONLIGHT_FPS}"
  MOONLIGHT_BITRATE="${BEAGLE_ENDPOINT_MOONLIGHT_BITRATE:-$MOONLIGHT_BITRATE}"
  MOONLIGHT_VIDEO_CODEC="${BEAGLE_ENDPOINT_MOONLIGHT_VIDEO_CODEC:-$MOONLIGHT_VIDEO_CODEC}"
  MOONLIGHT_VIDEO_DECODER="${BEAGLE_ENDPOINT_MOONLIGHT_VIDEO_DECODER:-$MOONLIGHT_VIDEO_DECODER}"
  MOONLIGHT_AUDIO_CONFIG="${BEAGLE_ENDPOINT_MOONLIGHT_AUDIO_CONFIG:-$MOONLIGHT_AUDIO_CONFIG}"
  MOONLIGHT_ABSOLUTE_MOUSE="${BEAGLE_ENDPOINT_MOONLIGHT_ABSOLUTE_MOUSE:-$MOONLIGHT_ABSOLUTE_MOUSE}"
  MOONLIGHT_QUIT_AFTER="${BEAGLE_ENDPOINT_MOONLIGHT_QUIT_AFTER:-$MOONLIGHT_QUIT_AFTER}"
  SUNSHINE_API_URL="${BEAGLE_ENDPOINT_SUNSHINE_API_URL:-$SUNSHINE_API_URL}"
  SUNSHINE_USERNAME="${BEAGLE_ENDPOINT_SUNSHINE_USERNAME:-$SUNSHINE_USERNAME}"
  SUNSHINE_PASSWORD="${BEAGLE_ENDPOINT_SUNSHINE_PASSWORD:-$SUNSHINE_PASSWORD}"
  SUNSHINE_PIN="${BEAGLE_ENDPOINT_SUNSHINE_PIN:-$SUNSHINE_PIN}"
  PROXMOX_HOST="${BEAGLE_ENDPOINT_PROXMOX_HOST:-$PROXMOX_HOST}"
  PROXMOX_PORT="${BEAGLE_ENDPOINT_PROXMOX_PORT:-$PROXMOX_PORT}"
  PROXMOX_NODE="${BEAGLE_ENDPOINT_PROXMOX_NODE:-$PROXMOX_NODE}"
  PROXMOX_VMID="${BEAGLE_ENDPOINT_PROXMOX_VMID:-$PROXMOX_VMID}"
  PROXMOX_REALM="${BEAGLE_ENDPOINT_PROXMOX_REALM:-$PROXMOX_REALM}"
  PROXMOX_VERIFY_TLS="${BEAGLE_ENDPOINT_PROXMOX_VERIFY_TLS:-$PROXMOX_VERIFY_TLS}"
  NETWORK_MODE="${BEAGLE_ENDPOINT_NETWORK_MODE:-$NETWORK_MODE}"
  NETWORK_INTERFACE="${BEAGLE_ENDPOINT_NETWORK_INTERFACE:-$NETWORK_INTERFACE}"
  NETWORK_STATIC_ADDRESS="${BEAGLE_ENDPOINT_NETWORK_STATIC_ADDRESS:-$NETWORK_STATIC_ADDRESS}"
  NETWORK_STATIC_PREFIX="${BEAGLE_ENDPOINT_NETWORK_STATIC_PREFIX:-$NETWORK_STATIC_PREFIX}"
  NETWORK_GATEWAY="${BEAGLE_ENDPOINT_NETWORK_GATEWAY:-$NETWORK_GATEWAY}"
  NETWORK_DNS_SERVERS="${BEAGLE_ENDPOINT_NETWORK_DNS_SERVERS:-$NETWORK_DNS_SERVERS}"
fi

if [[ -z "$AUTOSTART" ]]; then
  if [[ -n "$MOONLIGHT_HOST" ]]; then
    AUTOSTART="1"
  else
    AUTOSTART="0"
  fi
fi

if [[ -z "$SUNSHINE_API_URL" && -n "$MOONLIGHT_HOST" ]]; then
  SUNSHINE_API_URL="https://${MOONLIGHT_HOST}:47990"
fi

if [[ ! -x "$WRITE_CONFIG" ]]; then
  echo "Missing runtime config writer: $WRITE_CONFIG" >&2
  exit 1
fi

MODE="MOONLIGHT" \
RUNTIME_USER="$RUNTIME_USER" \
AUTOSTART="$AUTOSTART" \
PROFILE_NAME="$PROFILE_NAME" \
HOSTNAME_VALUE="$(hostname)" \
MOONLIGHT_HOST="$MOONLIGHT_HOST" \
MOONLIGHT_APP="$MOONLIGHT_APP" \
MOONLIGHT_BIN="moonlight" \
MOONLIGHT_RESOLUTION="$MOONLIGHT_RESOLUTION" \
MOONLIGHT_FPS="$MOONLIGHT_FPS" \
MOONLIGHT_BITRATE="$MOONLIGHT_BITRATE" \
MOONLIGHT_VIDEO_CODEC="$MOONLIGHT_VIDEO_CODEC" \
MOONLIGHT_VIDEO_DECODER="$MOONLIGHT_VIDEO_DECODER" \
MOONLIGHT_AUDIO_CONFIG="$MOONLIGHT_AUDIO_CONFIG" \
MOONLIGHT_ABSOLUTE_MOUSE="$MOONLIGHT_ABSOLUTE_MOUSE" \
MOONLIGHT_QUIT_AFTER="$MOONLIGHT_QUIT_AFTER" \
SUNSHINE_API_URL="$SUNSHINE_API_URL" \
PROXMOX_HOST="$PROXMOX_HOST" \
PROXMOX_PORT="$PROXMOX_PORT" \
PROXMOX_NODE="$PROXMOX_NODE" \
PROXMOX_VMID="$PROXMOX_VMID" \
PROXMOX_REALM="$PROXMOX_REALM" \
PROXMOX_VERIFY_TLS="$PROXMOX_VERIFY_TLS" \
NETWORK_MODE="$NETWORK_MODE" \
NETWORK_INTERFACE="$NETWORK_INTERFACE" \
NETWORK_STATIC_ADDRESS="$NETWORK_STATIC_ADDRESS" \
NETWORK_STATIC_PREFIX="$NETWORK_STATIC_PREFIX" \
NETWORK_GATEWAY="$NETWORK_GATEWAY" \
NETWORK_DNS_SERVERS="$NETWORK_DNS_SERVERS" \
SUNSHINE_USERNAME="$SUNSHINE_USERNAME" \
SUNSHINE_PASSWORD="$SUNSHINE_PASSWORD" \
SUNSHINE_PIN="$SUNSHINE_PIN" \
"$WRITE_CONFIG" /etc/pve-thin-client
